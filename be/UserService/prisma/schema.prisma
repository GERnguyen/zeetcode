 // This is your Prisma schema file,
 // learn more about it in the docs: https://pris.ly/d/prisma-schema
 
 // Get a free hosted Postgres database in seconds: `npx create-db`
 
 generator client {
   provider = "prisma-client"
   output   = "../src/generated/prisma"
 }
 
 datasource db {
   provider = "postgresql"
 }
 
 enum PrivacySetting {
   PUBLIC
   FOLLOWERS_ONLY
   PRIVATE
 }
 
 enum FollowStatus {
   PENDING
   ACCEPTED
   REJECTED
 }
 
 enum UserRole {
   USER
   ADMIN
 }

enum EmailTokenPurpose {
  SIGNUP_CONFIRM
  PASSWORD_RESET
  SENSITIVE_CHANGE
}
 
 model User {
   id                String         @id @default(uuid())
   username          String         @unique
   email             String         @unique
   password          String
   role              UserRole       @default(USER)
   profileVisibility PrivacySetting @default(PUBLIC)
  emailVerified     Boolean        @default(false)
  emailVerifiedAt   DateTime?
   createdAt         DateTime       @default(now())
 
   following         Followers[]    @relation("UserAsFollower")
   followers         Followers[]    @relation("UserAsFollowing")

  refreshTokens     RefreshToken[]
  emailTokens       EmailToken[]
 }
 
 model Followers {
   followerId  String
   followingId String
   status      FollowStatus @default(PENDING)
   
   createdAt   DateTime @default(now())
 
   follower    User     @relation("UserAsFollower", fields: [followerId], references: [id], onDelete: Cascade)
   following   User     @relation("UserAsFollowing", fields: [followingId], references: [id], onDelete: Cascade)
 
   @@id([followerId, followingId])
 }

model RefreshToken {
  id               String   @id @default(uuid())
  userId           String
  tokenHash        String
  expiresAt        DateTime
  revokedAt        DateTime?
  replacedByTokenId String?
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model EmailToken {
  id        String            @id @default(uuid())
  userId    String
  tokenHash String
  purpose   EmailTokenPurpose
  payload   String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}
 